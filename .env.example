# Copy this file to .env and fill the real secrets before running the app

# Server
PORT=5000
NODE_ENV=development

# MongoDB
# Example local URI: mongodb://localhost:27017/community-helpdesk
# For production use a managed DB and include credentials in the URI
MONGO_URI=mongodb+srv://admin:cyber123@cluster0.6mp0ecg.mongodb.net/?appName=Cluster0

# JSON Web Token (used for authentication)
# Use a long random string in production (do NOT commit your real secret)
JWT_SECRET=change_this_to_a_strong_secret
# Token expiry (e.g. 7d, 24h, 3600s)
JWT_EXPIRES_IN=7d

# Bcrypt salt rounds (optional override of the default used in code)
BCRYPT_SALT_ROUNDS=10

# Cookie secret (if you sign cookies)
COOKIE_SECRET=change_cookie_secret

# CORS: origin allowed to access the API (use the frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Logging level (optional)
LOG_LEVEL=info
